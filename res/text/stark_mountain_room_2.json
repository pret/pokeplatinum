    {
      "id": "StarkMountainRoom2_Text_LetsTeamUp",
      "en_US": [
        "Buck: Hey, {STRVAR_1 3, 0, 0}, wait up!\n",
        "So, what’s going on?\r",
        "...What?!\n",
        "Team Galactic’s here?\r",
        "Gotcha!\n",
        "Let’s team up and go together.\r"
      ]
    },
    {
      "id": "StarkMountainRoom2_Text_DecidedToGoWithBuck",
      "en_US": [
        "{STRVAR_1 3, 0, 0} decided to go with\n",
        "Buck!"
      ]
    },
    {
      "id": "StarkMountainRoom2_Text_IllKeepPokemonHealthy",
      "en_US": [
        "Buck: You won’t regret teaming up!\n",
        "I’ll keep your Pokémon healthy!"
      ]
    },
    {
      "id": "StarkMountainRoom2_Text_LetsGoTogether",
      "en_US": [
        "Buck: Team Galactic’s here, right?\n",
        "Let’s go together!\r"
      ]
    },
    {
      "id": "StarkMountainRoom2_Text_IllStickAround",
      "en_US": [
        "Buck: Whoa! Hold up!\r",
        "If you go back, you’ll leave me all by\n",
        "my lonesome here!\r",
        "Well, if you gotta go, you gotta go.\n",
        "I’ll stick around here for you.\r"
      ]
    },
    {
      "id": "StarkMountainRoom2_Text_HereWeAre",
      "en_US": [
        "Buck: Here we are!\n",
