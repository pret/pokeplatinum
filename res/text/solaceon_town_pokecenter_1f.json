  "messages": [
    {
      "id": "SolaceonTownPokecenter1F_Text_PokemonGrowAtDifferentRates",
      "en_US": [
        "The Day-Care Man was saying Pokémon\n",
        "grow at different rates."
      ]
    },
    {
      "id": "SolaceonTownPokecenter1F_Text_ItsQuiteFarToVeilstoneCity",
      "en_US": [
        "It’s quite far from Solaceon Town to\n",
        "Veilstone City.\r",
        "There’s a café along the way where\n",
        "you can get some rest, though."
      ]
    },
    {
      "id": "SolaceonTownPokecenter1F_Text_HMDefogIsInTheRuins",
      "en_US": [
        "The Hidden Machine Defog can be found\n",
        "in the Solaceon Ruins.\r",
        "But my Pokémon can’t learn the hidden\n",
        "move.\r",
        "I’m going to give the ruins a miss, this\n",
        "time."
      ]
    },
    {
      "id": "SolaceonTownPokecenter1F_Text_WillYouBattleMe",
      "en_US": [
        "Pikachu!\r",
        "I want to become more like a PIKACHU!\n",
        "Will you battle me?"
      ]
    },
    {
      "id": "SolaceonTownPokecenter1F_Text_PiPikachu",
      "en_US": "Pi-Pikachu!\r"
    },
    {
      "id": "SolaceonTownPokecenter1F_Text_PiPikachu2",
      "en_US": "Pi-Pikachu!"
    },
    {
      "id": "SolaceonTownPokecenter1F_Text_INeedToGetMoreIntoCharacter",
      "en_US": [
        "I need to find a way to get more into\n",
        "the character of a Pokémon...\r",
        "Maybe I should get the Day Care to\n",
        "raise me?"
      ]
    }
  ]
}
