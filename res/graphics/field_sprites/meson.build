field_sprites_narc = custom_target(field_sprites_target_name,
    output: [
        'field_sprites.narc',
        'field_sprites.naix'
    ],
    input: [
        field_sprites_nsbtxs,
        field_sprites_nsbmds,
        field_sprites_anims,
    ],
    command: [
        nitroarc_exe,
        '--create',
        '--index',
        '--files-from', files('field_sprites.order'),
        '--file', '@OUTPUT0@',
        '@PRIVATE_DIR@',
    ],
)

nitrofs_files += field_sprites_narc
naix_headers += field_sprites_narc[1]
