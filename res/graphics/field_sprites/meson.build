field_sprites_nsbtxs += custom_target(
    input: [
        'objects/cave_painting/t5_o01_c.png',
        'objects/cave_painting/t5_o01_c_.png'
    ],
    build_subdir: field_sprites_private_dir,
    output: 'cave_painting.nsbtx',
    command: [
        nitrobtx_exe,
        'pack',
        '--texture', '@INPUT0@',
        '--name', 't5_o01_c',
        '--extract-palette',
        '--palette-suffix',
        '--texture', '@INPUT1@',
        '--name', 't5_o01_c_',
        '--extract-palette',
        '--palette-suffix',
        '@OUTPUT@'
    ],
)

